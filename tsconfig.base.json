{
    "compileOnSave": false,
    "compilerOptions": {
        "rootDir": ".",
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "node",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "importHelpers": true,
        "target": "es2015",
        "module": "esnext",
        "lib": ["es2020", "dom"],
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@inventory/core/decorators": [
                "libs/core/src/lib/decorators/index.ts"
            ],
            "@inventory/core/domain": ["libs/core/src/lib/domain/index.ts"],
            "@inventory/core/errors": ["libs/core/src/lib/errors/index.ts"],
            "@inventory/core/guards": ["libs/core/src/lib/guards/index.ts"],
            "@inventory/core/interceptors": [
                "libs/core/src/lib/interceptors/index.ts"
            ],
            "@inventory/core/logging": ["libs/core/src/lib/logging/index.ts"],
            "@inventory/core/validation": [
                "libs/core/src/lib/validation/index.ts"
            ],
            "@inventory/core": ["libs/core/src/index.ts"],
            "@inventory/database/type-orm-config": [
                "libs/database/src/lib/type-orm-config/index.ts"
            ],
            "@inventory/database": ["libs/database/src/index.ts"],
            "@inventory/shared/domain": ["libs/shared/src/lib/domain/index.ts"],
            "@inventory/shared/infrastructure": [
                "libs/shared/src/lib/infrastructure/index.ts"
            ],
            "@inventory/shared/registry": [
                "libs/shared/src/lib/registry/index.ts"
            ],
            "@inventory/shared": ["libs/shared/src/index.ts"],
            "@inventory/user/domain": ["libs/user/src/lib/domain/index.ts"],
            "@inventory/user/application": [
                "libs/user/src/lib/application/index.ts"
            ],
            "@inventory/user/infrastructure": [
                "libs/user/src/lib/infrastructure/index.ts"
            ],
            "@inventory/user": ["libs/user/src/index.ts"],
            "@inventory/auth/domain": ["libs/auth/src/lib/domain/index.ts"],
            "@inventory/auth/application": [
                "libs/auth/src/lib/application/index.ts"
            ],
            "@inventory/auth/infrastructure": [
                "libs/auth/src/lib/infrastructure/index.ts"
            ],
            "@inventory/auth/presentation": [
                "libs/auth/src/lib/presentation/index.ts"
            ],
            "@inventory/auth": ["libs/auth/src/index.ts"],
            "@inventory/inventory": ["libs/inventory/src/index.ts"],
            "@inventory/inventory/domain": ["libs/inventory/src/lib/domain/index.ts"],
            "@inventory/inventory/application": [
                "libs/inventory/src/lib/application/index.ts"
            ],
            "@inventory/inventory/infrastructure": [
                "libs/inventory/src/lib/infrastructure/index.ts"
            ],
            "@inventory/inventory/presentation": [
                "libs/inventory/src/lib/presentation/index.ts"
            ],
        }
    },
    "exclude": ["node_modules", "tmp"]
}
