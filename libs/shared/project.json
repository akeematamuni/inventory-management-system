{
    "name": "shared",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/shared/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "tsc -p libs/shared/tsconfig.lib.json && tsc-alias -p libs/shared/tsconfig.lib.json"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
